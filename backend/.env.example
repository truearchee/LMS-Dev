DATABASE_URL="file:./prisma/dev.db"
JWT_SECRET="change-me-in-production-must-be-32-or-more-characters"
JWT_EXPIRES_IN="15m"
REFRESH_EXPIRES_IN="7d"
NODE_ENV="development"
PORT="3001"

# Storage (local for dev, s3 or r2 for production)
STORAGE_PROVIDER="local"
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_KEY_ID=""
STORAGE_SECRET=""

# AI provider (set to 'mock' for dev without API key, 'k2' for real AI)
AI_PROVIDER=mock
AI_API_KEY=your-api-key-here
AI_MODEL=MBZUAI-IFM/K2-Think-v2
AI_BASE_URL=https://api.k2think.ai/v1
