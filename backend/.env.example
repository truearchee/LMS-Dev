DATABASE_URL="file:./prisma/dev.db"
JWT_SECRET="change-me-in-production-must-be-32-or-more-characters"
JWT_EXPIRES_IN="15m"
REFRESH_EXPIRES_IN="7d"
NODE_ENV="development"
PORT="3001"

# Storage (local for dev, s3 or r2 for production)
STORAGE_PROVIDER="local"
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_KEY_ID=""
STORAGE_SECRET=""

# AI provider (leave blank to use mock provider)
AI_PROVIDER=""
AI_API_KEY=""
