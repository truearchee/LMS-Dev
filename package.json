{
  "name": "lms-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend & npm run dev --workspace=backend",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
